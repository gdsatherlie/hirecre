# ------------------------------------------------------------------
# HireCRE — required environment variables
# Copy this file to .env.local for development, or set each key in
# your hosting platform (Coolify → Environment Variables) for prod.
# ------------------------------------------------------------------

# --- Supabase: public (exposed to browser) ---
# Find these in Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase: server-only (NEVER expose to the browser) ---
# The service role key bypasses Row Level Security. Used by:
#   - /api/subscribe  (upserts into newsletter_subscribers)
#   - /app/jobs/[slug]/page.tsx  (reads jobs bypassing RLS)
#   - /scripts/**                 (ETL and newsletter jobs)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...SERVICE_ROLE_KEY...

# --- Site URL (used by sitemap, canonical URLs, robots.txt) ---
NEXT_PUBLIC_SITE_URL=https://hirecre.com

# --- Google Analytics (optional) ---
# If unset, GA snippet is not rendered at all.
NEXT_PUBLIC_GTAG_ID=G-XXXXXXXXXX

# --- MailerLite (newsletter subscriptions + alerts) ---
MAILERLITE_API_TOKEN=
MAILERLITE_GROUP_ID=          # generic newsletter group
MAILERLITE_ALERTS_GROUP_ID=   # saved-search alerts group

# --- MailerSend (transactional alert emails) ---
MAILERSEND_API_KEY=

# --- Email sender identity (used by scripts/run-saved-search-alerts.mjs) ---
ALERT_FROM_EMAIL=HireCRE@your-domain.com
ALERT_FROM_NAME=HireCRE

# --- Coolify / nixpacks build ---
# Pin the Node version used by the nixpacks build pack.
NIXPACKS_NODE_VERSION=20
